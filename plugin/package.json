{
  "name": "openclaw-channel-whatsapp-official",
  "version": "0.1.14",
  "description": "Official WhatsApp Business API for OpenClaw — pair via QR in 2 minutes using imBee's verified number. No Meta verification or server setup required. Free tier available; dedicated numbers for enterprise.",
  "author": {
    "name": "imBee Limited",
    "email": "info@imbee.io",
    "url": "https://imbee.io"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dearken10/openclaw-whatsapp-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/dearken10/openclaw-whatsapp-plugin/issues"
  },
  "homepage": "https://github.com/dearken10/openclaw-whatsapp-plugin#readme",
  "type": "module",
  "main": "./index.ts",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "whatsapp",
    "channel",
    "imbee"
  ],
  "files": [
    "LICENSE",
    "README.md",
    "index.ts",
    "setup-entry.ts",
    "openclaw.plugin.json",
    "schema",
    "src"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.4.15"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "compat": {
      "pluginApi": ">=2026.4.15",
      "minGatewayVersion": "2026.4.15"
    },
    "build": {
      "openclawVersion": "2026.4.15",
      "pluginSdkVersion": "2026.4.15"
    },
    "channel": {
      "id": "whatsapp-official",
      "label": "Official WhatsApp API (imBee)",
      "selectionLabel": "Official WhatsApp API (imBee)",
      "detailLabel": "WhatsApp Official",
      "docsPath": "/channels/whatsapp-official",
      "docsLabel": "whatsapp-official",
      "blurb": "Managed official WhatsApp Cloud API channel via imBee routing service.",
      "systemImage": "message-circle",
      "order": 130
    }
  },
  "dependencies": {
    "openclaw": ">=2026.4.15",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5"
  }
}
