# URL of the routing backend — used by both the backend itself and the OpenClaw plugin
ROUTING_BASE_URL=http://localhost:28080
# STORE_DRIVER selects the persistence backend:
#   memory   — in-process only, lost on restart (dev/testing)
#   sqlite   — SQLite file, survives restarts, no server needed (recommended for single-instance)
#   file     — legacy JSON file (superseded by sqlite)
#   postgres — PostgreSQL (recommended for production / multi-replica)
STORE_DRIVER=sqlite
STORE_FILE_PATH=./data/store.db
# Uncomment below if using postgres instead:
# STORE_DRIVER=postgres
# POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/whatsapp_plugin?sslmode=disable
SHARED_WA_NUMBER=+85230013143
WEBHOOK_APP_SECRET=dev-secret
# Must match the "Verify token" you set in the Meta app / 360dialog Hub webhook dashboard
WEBHOOK_VERIFY_TOKEN=
PAIRING_CODE_TTL_SECONDS=600
PAIR_RATE_LIMIT_PER_HOUR=5

# ── WhatsApp outbound provider ────────────────────────────────────────────────
# WA_PROVIDER selects the delivery backend:
#   meta       — Meta WhatsApp Cloud API directly
#   360dialog  — 360dialog Cloud API (BSP)
#   (empty)    — stub / dev mode, no real messages sent
WA_PROVIDER=

# Meta Cloud API (required when WA_PROVIDER=meta)
WABA_TOKEN=
WABA_PHONE_NUMBER_ID=

# 360dialog (required when WA_PROVIDER=360dialog)
D360_API_KEY=   # used for sending messages and registering webhooks via scripts/ngrok-up.sh
# D360_BASE_URL=https://waba-v2.360dialog.io   # override for sandbox: https://waba-sandbox.360dialog.io
